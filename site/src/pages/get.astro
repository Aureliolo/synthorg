---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Get SynthOrg — Install the CLI">
  <!-- ============================================================ -->
  <!-- HERO (compact) -->
  <!-- ============================================================ -->
  <section class="relative pt-24 pb-16 px-6">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0F1219] via-[#1a1025] to-[#0F1219]"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4">
        Get
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400">
          SynthOrg
        </span>
      </h1>
      <p class="text-lg text-gray-400 max-w-xl mx-auto">
        Install the CLI to set up and manage your synthetic organization in seconds.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- QUICK INSTALL (CLI) -->
  <!-- ============================================================ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Quick Install</h2>

      <!-- Linux / macOS -->
      <div class="mb-6">
        <p class="text-sm text-gray-400 mb-2 font-mono">Linux / macOS</p>
        <div class="relative bg-[#0d1117] rounded-xl border border-white/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2.5 bg-[#161b22] border-b border-white/10">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="ml-2 text-xs text-gray-500 font-mono">bash</span>
            </div>
            <button
              class="copy-btn text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded hover:bg-white/5"
              data-code="curl -sSfL https://synthorg.io/get/install.sh | bash"
              aria-label="Copy to clipboard"
            >
              Copy
            </button>
          </div>
          <pre class="p-4 text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto leading-relaxed"><code><span class="text-gray-500">$</span> curl -sSfL https://synthorg.io/get/install.sh | bash</code></pre>
        </div>
      </div>

      <!-- Windows -->
      <div class="mb-8">
        <p class="text-sm text-gray-400 mb-2 font-mono">Windows (PowerShell)</p>
        <div class="relative bg-[#0d1117] rounded-xl border border-white/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2.5 bg-[#161b22] border-b border-white/10">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="ml-2 text-xs text-gray-500 font-mono">powershell</span>
            </div>
            <button
              class="copy-btn text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded hover:bg-white/5"
              data-code="irm https://synthorg.io/get/install.ps1 | iex"
              aria-label="Copy to clipboard"
            >
              Copy
            </button>
          </div>
          <pre class="p-4 text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto leading-relaxed"><code><span class="text-gray-500">PS&gt;</span> irm https://synthorg.io/get/install.ps1 | iex</code></pre>
        </div>
      </div>

      <!-- Post-install -->
      <div class="bg-[#1a1f2e] rounded-xl p-6 border border-violet-500/20">
        <p class="text-sm text-gray-400 mb-3">Then set up and start your organization:</p>
        <div class="relative bg-[#0d1117] rounded-xl border border-white/10 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2.5 bg-[#161b22] border-b border-white/10">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="ml-2 text-xs text-gray-500 font-mono">terminal</span>
            </div>
            <button
              class="copy-btn text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded hover:bg-white/5"
              data-code="synthorg init&#10;synthorg start"
              aria-label="Copy to clipboard"
            >
              Copy
            </button>
          </div>
          <pre class="p-4 text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto leading-relaxed"><code><span class="text-gray-500">$</span> synthorg init      <span class="text-gray-600"># interactive setup wizard</span>
<span class="text-gray-500">$</span> synthorg start     <span class="text-gray-600"># pull images + start containers</span></code></pre>
        </div>
        <p class="text-xs text-gray-500 mt-3">
          The web dashboard opens at <code class="text-gray-400">http://localhost:3000</code> (default).
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- AUDIT THE SCRIPTS -->
  <!-- ============================================================ -->
  <section class="py-16 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1f2e]">
    <div class="max-w-3xl mx-auto">
      <div class="bg-[#0F1219] rounded-xl p-8 border border-teal-500/20">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 text-xl shrink-0">&#128270;</div>
          <div>
            <h2 class="text-xl font-semibold mb-2">Look before you pipe</h2>
            <p class="text-gray-400 mb-4">
              Review what the install scripts do before running them. Both scripts download a pre-built binary from
              <a href="https://github.com/Aureliolo/synthorg/releases" class="text-teal-400 hover:underline">GitHub Releases</a>,
              verify its SHA-256 checksum, and place it in your PATH.
            </p>
            <div class="flex flex-wrap gap-3">
              <a
                href="https://github.com/Aureliolo/synthorg/blob/main/cli/scripts/install.sh"
                class="inline-flex items-center gap-2 px-4 py-2 bg-teal-600/10 border border-teal-500/30 rounded-lg text-teal-400 text-sm hover:bg-teal-600/20 transition-colors"
              >
                View install.sh on GitHub
              </a>
              <a
                href="https://github.com/Aureliolo/synthorg/blob/main/cli/scripts/install.ps1"
                class="inline-flex items-center gap-2 px-4 py-2 bg-teal-600/10 border border-teal-500/30 rounded-lg text-teal-400 text-sm hover:bg-teal-600/20 transition-colors"
              >
                View install.ps1 on GitHub
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- DIRECT DOWNLOAD -->
  <!-- ============================================================ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-center">Direct Download</h2>
      <p class="text-gray-400 text-center mb-8">
        Download the install scripts and run them locally instead of piping from the network.
      </p>

      <div class="grid sm:grid-cols-2 gap-4">
        <a
          href="/get/install.sh"
          download
          class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors text-center no-underline"
        >
          <p class="font-semibold text-violet-400 mb-1">install.sh</p>
          <p class="text-xs text-gray-500">Linux / macOS</p>
        </a>
        <a
          href="/get/install.ps1"
          download
          class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors text-center no-underline"
        >
          <p class="font-semibold text-violet-400 mb-1">install.ps1</p>
          <p class="text-xs text-gray-500">Windows (PowerShell)</p>
        </a>
      </div>

      <div class="mt-4 text-center">
        <p class="text-xs text-gray-500">
          Then run: <code class="text-gray-400">bash install.sh</code> or <code class="text-gray-400">.\install.ps1</code>
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- MANUAL CLI DOWNLOAD -->
  <!-- ============================================================ -->
  <section class="py-16 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1f2e]">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-center">Manual Download</h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-8">
        Prefer to skip the install script entirely? Grab the binary directly from GitHub Releases.
      </p>

      <div class="bg-[#0F1219] rounded-xl p-8 border border-white/10">
        <ol class="space-y-4 text-gray-400">
          <li class="flex gap-3">
            <span class="w-7 h-7 rounded-full bg-violet-600/20 flex items-center justify-center text-violet-400 text-sm font-bold shrink-0">1</span>
            <span>Go to <a href="https://github.com/Aureliolo/synthorg/releases/latest" class="text-teal-400 hover:underline">GitHub Releases</a> and download the archive for your platform (<code class="text-gray-300">synthorg_linux_amd64.tar.gz</code>, <code class="text-gray-300">synthorg_darwin_arm64.tar.gz</code>, <code class="text-gray-300">synthorg_windows_amd64.zip</code>, etc.).</span>
          </li>
          <li class="flex gap-3">
            <span class="w-7 h-7 rounded-full bg-violet-600/20 flex items-center justify-center text-violet-400 text-sm font-bold shrink-0">2</span>
            <span>Download <code class="text-gray-300">checksums.txt</code> from the same release and verify: <code class="text-gray-300">sha256sum -c checksums.txt</code></span>
          </li>
          <li class="flex gap-3">
            <span class="w-7 h-7 rounded-full bg-violet-600/20 flex items-center justify-center text-violet-400 text-sm font-bold shrink-0">3</span>
            <span>Extract the binary and move it to a directory in your <code class="text-gray-300">PATH</code>.</span>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CLI IS OPTIONAL -->
  <!-- ============================================================ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">The CLI is optional</h2>
      <p class="text-gray-400 max-w-xl mx-auto mb-6">
        The CLI automates Docker Compose setup, image pulling, health checks, and updates.
        If you're comfortable with Docker, you can run the containers directly.
      </p>
      <a
        href="/docs/user_guide/"
        class="inline-block px-8 py-3 border border-teal-400/50 text-teal-400 hover:bg-teal-400/10 rounded-lg font-semibold transition-colors"
      >
        Manual Docker Compose setup
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FOOTER -->
  <!-- ============================================================ -->
  <Footer />

  <!-- Copy button script -->
  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const code = this.getAttribute('data-code') || '';
        navigator.clipboard.writeText(code).then(() => {
          const el = this as HTMLElement;
          el.textContent = 'Copied!';
          setTimeout(() => { el.textContent = 'Copy'; }, 2000);
        });
      });
    });
  </script>
</Base>
